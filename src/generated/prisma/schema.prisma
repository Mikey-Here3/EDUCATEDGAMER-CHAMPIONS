// Educated Gamer Champions - Prisma Schema
// Neon PostgreSQL database for esports tournament platform

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth Models (NextAuth Adapter) ──────────────────────────────────────────

enum Role {
  USER
  ADMIN
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  role          Role      @default(USER)
  gamertag      String?
  phone         String?

  accounts      Account[]
  sessions      Session[]
  registrations Registration[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Tournament Models ───────────────────────────────────────────────────────

enum TournamentType {
  SOLO
  SQUAD
  BOTH
}

enum TournamentStatus {
  UPCOMING
  LIVE
  COMPLETED
}

model Tournament {
  id              String           @id @default(cuid())
  name            String
  slug            String           @unique
  game            String
  bannerImage     String?
  description     String?          @db.Text
  type            TournamentType   @default(SOLO)
  status          TournamentStatus @default(UPCOMING)
  maxSlots        Int              @default(100)
  registeredCount Int              @default(0)
  entryFee        Float            @default(0)
  prizePool       String?
  startDate       DateTime
  endDate         DateTime?
  rules           String?          @db.Text
  discordLink     String?
  whatsappLink    String?
  youtubeLink     String?

  registrations Registration[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
  @@index([status])
  @@index([startDate])
}

// ─── Registration Models ─────────────────────────────────────────────────────

enum RegistrationType {
  SOLO
  SQUAD
}

enum RegistrationStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  VERIFIED
  REJECTED
}

model Registration {
  id                String             @id @default(cuid())
  tournamentId      String
  userId            String?
  teamName          String?
  playerName        String
  email             String
  phone             String?
  gamertag          String
  gameUID           String?
  type              RegistrationType   @default(SOLO)
  status            RegistrationStatus @default(PENDING)
  paymentStatus     PaymentStatus      @default(PENDING)
  paymentScreenshot String?
  uidScreenshot     String?

  tournament  Tournament   @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  user        User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  teamMembers TeamMember[]

  createdAt DateTime @default(now())

  @@index([tournamentId])
  @@index([userId])
  @@index([email])
}

model TeamMember {
  id             String  @id @default(cuid())
  registrationId String
  playerName     String
  gamertag       String
  gameUID        String?

  registration Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)

  @@index([registrationId])
}
